import Mathlib

variable {C : Type u} [Category.{v} C] [HasZeroMorphisms C] (S : ShortComplex C)
  {S₁ S₂ S₃ S₄ : ShortComplex C}

variable (φ : S₁ ⟶ S₂) (h₁ : S₁.HomologyData) (h₂ : S₂.HomologyData)

variable {C} {A : C}

theorem RightHomologyData.canonical_g' [S.HasHomology] :
    (CategoryTheory.ShortComplex.RightHomologyData.canonical S).g' = S.fromOpcycles := rfl

